        "#| label: vizualizacia-3d\n",
        "#| echo: true\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# vytvoríme sieť bodov\n",
        "\n",
        "x = np.linspace(-3, 3, 50)\n",
        "y = np.linspace(-3, 3, 50)\n",
        "X, Y = np.meshgrid(x, y)\n",
        "\n",
        "# funkcia \n",
        "F = X**2 * Y + X * Y**2\n",
        "\n",
        "# 3D graf\n",
        "fig = plt.figure(figsize=(8,6))\n",
        "ax = fig.add_subplot(111, projection = '3d')\n",
        "\n",
        "ax.plot_surface(X, Y, F, cmap='rainbow', alpha = 0.85)\n",
        "\n",
        "ax.set_xlabel('x')\n",
        "ax.set_ylabel('y')\n",
        "ax.set_zlabel('f(x, y)')\n",
        "ax.set_title('Graf funkcie f(x, y) = x²y + xy²')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
