   "source": [
    "#| label: smerova-derivacia\n",
    "#| echo: true\n",
    "\n",
    "import sympy as sp\n",
    "\n",
    "x, y = sp.symbols('x y')\n",
    "\n",
    "f = x**2 * y + x * y**2\n",
    "\n",
    "df_dx = sp.diff(f, x)\n",
    "df_dy = sp.diff(f, y)\n",
    "\n",
    "# gradient\n",
    "gradient = sp.Matrix([df_dx, df_dy])\n",
    "\n",
    "# bod B a vektor v\n",
    "\n",
    "bod_B = {x:1, y:2}\n",
    "\n",
    "v = sp.Matrix([3, 4])\n",
    "\n",
    "#gradient v bode B\n",
    "gradient_B = gradient.subs(bod_B)\n",
    "\n",
    "# normalizovaný vektor\n",
    "v_norm = v / v.norm()\n",
    "\n",
    "# smerová derivácia\n",
    "D_v = gradient_B.dot(v_norm)\n",
    "D_v = sp.simplify(D_v)\n",
    "\n",
    "print(\"Gradient =\", gradient)\n",
    "print(\"Gradient v bode B =\", gradient_B)\n",
    "print(\"Smerová derivácia =\", D_v)"
   ]
